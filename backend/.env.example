# Port to run the Express backend on
PORT=5000

# MongoDB Connection String URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/designerportal?retryWrites=true&w=majority

# Secret key used for signing JWT tokens. Change this to a random secure string in production.
JWT_SECRET=your_secure_random_jwt_secret_key_here

# Initial setup credentials for the Admin user
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_to_a_secure_admin_password_123
ADMIN_NAME=Admin User

# Allowed origins for CORS (comma-separated). Set to client URL in production.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
